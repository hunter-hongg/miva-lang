module main;

Box[T] = enum {
    Value(T),
    Empty
}

process = (b: Box[int]) => choose (b) {
    when (Box.Value(v)) { return v * 2; }
    otherwise { return 0; }
}

main = () => {
    let b Box[int] = Box.Value(21);
    printlns!("double: ", process(b));
    let bad Box[string] = Box.Value("oops");
    printlns!("bad: ", process(bad));
}
