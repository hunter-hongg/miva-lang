module std.mem;

unsafe alloc = (ref size: int): ptrany => {
  ptr_alloc(size);
}

unsafe realloc = (ref p: ptrany, size: int): ptrany => {
  ptr_realloc(p, size);
}

unsafe mem_free = (ref p: ptrany) => {
  ptr_free(p);
}

unsafe offset = (ref p: ptrany, n: int): ptrany => ptr_offset(p, n)

export alloc;
export realloc;
export mem_free;
export offset;